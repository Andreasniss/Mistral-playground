# LLM_BACKEND: "api" (Mistral cloud) or "local" (Ollama, no API key needed)
# To run locally: set LLM_BACKEND=local and MISTRAL_MODEL=mistral (7B via Ollama)
LLM_BACKEND=api

MISTRAL_API_KEY=your_mistral_api_key_here
# Cloud model (used when LLM_BACKEND=api): mistral-large-latest, mistral-small-latest, etc.
# Local model  (used when LLM_BACKEND=local): mistral (7B), mistral-nemo (12B), mistral-small (24B)
MISTRAL_MODEL=mistral-large-latest

# Ollama server URL — only needed when LLM_BACKEND=local. Default matches `ollama serve`.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Set the maximum number of tokens for the response. Adjust based on your needs and API limits.
MISTRAL_MAX_TOKENS=1024
# Adjust the temperature for more creative (higher) or more deterministic (lower) responses.
MISTRAL_TEMPERATURE=0.0
# MISTRAL_TOP_P=0.9  # Uncomment to use nucleus sampling instead of temperature (do not use both)
LOG_LEVEL=INFO
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=0.5
RETRY_MAX_DELAY=60.0

# Required only when running the FastAPI server (api.py).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_api_key_here
